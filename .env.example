# Copy to .env for local deploy defaults. The real .env is gitignored because
# MCP_PATH is effectively the hosted server password.

# Leave empty to let scripts/deploy_modal.sh generate and persist a secret path.
# To choose your own path, set it here (e.g. /my-secret-path/mcp) and deploy with
# `make deploy-local-secret` to push exactly this value to Modal.
MCP_PATH=

# Data source for Modal deploys:
# release = hydrate from GitHub releases, skipping files already present unless forced
# local   = upload from DATA_DIR
# none    = deploy code only and never touch data
DATA_SOURCE=release

# Set to 1 to overwrite existing Modal Volume data.
FORCE_DATA=0

# Used only when DATA_SOURCE=local. Empty means this repo's ./data directory.
DATA_DIR=

# Release source used by DATA_SOURCE=release.
VRO_DATA_REPO=Leo-Martin-Pala/voro-mcp
VRO_DATA_TAG=data-v1
VRO_GIELLA_TAG=giella-v1
